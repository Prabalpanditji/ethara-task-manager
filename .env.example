# Project Management App - Root .env Examples

# Backend Configuration
# ====================

# Copy these to backend/.env

BACKEND_PORT=5000
BACKEND_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/project-manager?retryWrites=true&w=majority
BACKEND_JWT_SECRET=your-super-secret-key-change-this-in-production-to-something-random
BACKEND_NODE_ENV=development

# Frontend Configuration
# ====================

# Copy these to frontend/.env

FRONTEND_VITE_API_URL=http://localhost:5000/api
FRONTEND_VITE_ENV=development

# How to Get MongoDB URI
# ======================

# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Sign up (free tier available)
# 3. Create a new project and cluster
# 4. Click "Connect" on your cluster
# 5. Select "Connect your application"
# 6. Copy the connection string
# 7. Replace <username> and <password> with your credentials

# Example MongoDB URIs
# ====================

# Local development (if you have MongoDB installed locally):
# BACKEND_MONGODB_URI=mongodb://localhost:27017/project-manager

# MongoDB Atlas (cloud - recommended):
# BACKEND_MONGODB_URI=mongodb+srv://username:password@mycluster.mongodb.net/project-manager?retryWrites=true&w=majority

# Notes on JWT_SECRET
# ===================

# Generate a strong random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Or use an online generator: https://www.uuidgenerator.net/

# Port Configuration
# ==================

# Backend: Can use any free port (3000, 3001, 5000, 5001, 8000, etc.)
# Frontend: Dev server typically uses 3000 or 5173 (Vite default)

# Common Ports:
# - 3000: Vite dev server (default)
# - 5000: Express API (default)
# - 8000: Alternative API
# - 8080: Alternative API

# Environment Variables
# ====================

# NODE_ENV values:
# - development: More logging, more error details
# - production: Optimized, minimal logging

# VITE_ENV values:
# - development: HMR enabled, detailed errors
# - production: Optimized for production
